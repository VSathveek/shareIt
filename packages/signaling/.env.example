# Signaling service configuration
PORT=8080
HOST=0.0.0.0
# Comma-separated allowed browser origins (empty = allow all; set in production)
ORIGIN_ALLOWLIST=
LOG_LEVEL=info

# ICE / NAT traversal
STUN_URLS=stun:stun.l.google.com:19302
# Managed TURN (leave TURN_URLS/TURN_SECRET empty to advertise STUN only)
TURN_URLS=
TURN_SECRET=
TURN_TTL=86400
